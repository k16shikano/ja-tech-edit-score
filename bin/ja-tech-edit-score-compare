#!/usr/bin/env bash
# Compare two revision candidates from any directory.
set -euo pipefail

JA_TECH_EDIT_SCORE_HOME="${JA_TECH_EDIT_SCORE_HOME:-${HOME}/dev/ja-tech-edit-score}"
PYTHON="${JA_TECH_EDIT_SCORE_PYTHON:-${JA_TECH_EDIT_SCORE_HOME}/.venv/bin/python3}"
MODEL="${JA_TECH_EDIT_SCORE_MODEL:-${JA_TECH_EDIT_SCORE_HOME}/outputs/pref-static}"

if [[ ! -x "${PYTHON}" ]]; then
  PYTHON=python3
fi

if [[ $# -eq 0 ]]; then
  echo "usage: ja-tech-edit-score-compare --source-file ... --candidate-a-file ... --candidate-b-file ..." >&2
  echo "   or: ja-tech-edit-score-compare --source-text ... --candidate-a ... --candidate-b ..." >&2
  exit 1
fi

exec "${PYTHON}" "${JA_TECH_EDIT_SCORE_HOME}/scripts/compare_pref_candidates_static.py" \
  --model "${MODEL}" \
  "$@"
